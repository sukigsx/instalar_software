                    echo ""; sleep 4
                fi
                ;;

            "4")#xfce4
                nombre_paquete="xfce4"
                nombre_paquete_comprobar="xfce4"
                if yay -Si "$nombre_paquete" &>/dev/null; then
                    #codigo para la instalacion se mete a /tmp/software
                    echo "#$nombre_paquete" >> /tmp/software #mete el nombre del programa para poder comprobar su instalacion
                    echo "yay -S --noconfirm $nombre_paquete xfce4-goodies" >> /tmp/software
