CrearInstalarSoftware(){
#pregunta si quiero guardar la instalacion
if zenity --question --title="Instalacion de software - MegaTools -" --text="¿Quieres guardar un script de instalacion del software seleccionado?\n\nSe guardara en tu escritorio." --cancel-label="No" --ok-label="Si"
then
    #entra si la respuesta es si
    if [ -d /home/$(whoami)/Escritorio ]
    then
        #rm /tmp/software /home/$(whoami)/Escritorio/InstalarSosftware.sh 2>/dev/null
        cp /tmp/software /home/$(whoami)/Escritorio/InstalarSosftware.sh
    else
        #rm /tmp/software /home/$(whoami)/Desktop/InstalarSoftware.sh 2>/dev/null
        cp /tmp/software /home/$(whoami)/Desktop/InstalarSoftware.sh
    fi
else
    echo ""
fi
}




crear_ficheros_instalacion(){
#crea el fichero de instalacion de software

# Limpiamos el fichero antes de empezar
> /tmp/comprobacion

echo 'rojo="\e[0;31m\033[1m"' >> /tmp/comprobacion
echo 'verde="\e[0;32m\033[1m"' >> /tmp/comprobacion
echo 'azul="\e[0;34m\033[1m"' >> /tmp/comprobacion
echo 'amarillo="\e[0;33m\033[1m"' >> /tmp/comprobacion
echo 'rosa="\e[0;35m\033[1m"' >> /tmp/comprobacion
echo 'turquesa="\e[0;36m\033[1m"' >> /tmp/comprobacion
echo 'naranja="\e[0;33m\033[1m"' >> /tmp/comprobacion
echo 'borra_colores="\033[0m\e[0m"' >> /tmp/comprobacion
echo '' >> /tmp/comprobacion
echo 'echo -e "\n -Comprobacion de software instalado -\n"; sleep 2' >> /tmp/comprobacion
echo '' >> /tmp/comprobacion
echo 'echo -e "${azul}EXPLICACION:${borra_colores}"' >> /tmp/comprobacion
echo 'echo -e "${verde}SNAP${borra_colores} = Instalacion por paqueteria de Snap."' >> /tmp/comprobacion
echo 'echo -e "${verde}FLATPAK${borra_colores} = Instalacion por paqueteria de Flatpak."' >> /tmp/comprobacion
echo 'echo -e "${verde}REPOSITORIO${borra_colores} = Repositorios oficiales de tu distribucion."' >> /tmp/comprobacion
echo 'echo -e "${verde}SERVICIO${borra_colores} = Son servicios, como apache, ftp, openvpn, ssh, etc."' >> /tmp/comprobacion
echo 'echo -e "${verde}REPOSITORIO AÑADIDO${borra_colores} = Instalacion por repositorios del software."' >> /tmp/comprobacion
echo 'echo ""' >> /tmp/comprobacion
echo '{' >> /tmp/comprobacion
echo '    # Cabecera de la tabla' >> /tmp/comprobacion
echo '    echo -e "${azul}SOFTWARE\tMODO DE INSTALACION\tINSTALADO${borra_colores}"' >> /tmp/comprobacion
echo '    echo -e "--------\t-------------------\t-----------"' >> /tmp/comprobacion
echo '    # Bucle que genera el contenido' >> /tmp/comprobacion
echo '    for programa in $(cat /tmp/ComprobarSoftware); do' >> /tmp/comprobacion
echo '        if command -v snap >/dev/null 2>&1 && snap list 2>/dev/null | awk '"'"'{print $1}'"'"' | grep -qx "$programa"; then' >> /tmp/comprobacion
echo '            echo -e "$programa\t${azul}(Por Snap)${borra_colores}\t${verde}[OK]${borra_colores}"' >> /tmp/comprobacion
echo '        elif command -v flatpak >/dev/null 2>&1 && flatpak list --columns=application 2>/dev/null | grep -qx "$programa"; then' >> /tmp/comprobacion
echo '            echo -e "$programa\t${amarillo}(Por Flatpak)${borra_colores}\t${verde}[OK]${borra_colores}"' >> /tmp/comprobacion
echo '        elif command -v dpkg >/dev/null 2>&1 && dpkg -l 2>/dev/null | awk '"'"'{print $2}'"'"' | grep -qx "$programa"; then' >> /tmp/comprobacion
echo '            echo -e "$programa\t${rosa}(Por repositorio)${borra_colores}\t${verde}[OK]${borra_colores}"' >> /tmp/comprobacion
echo '        elif systemctl list-units --type=service 2>/dev/null | grep -q "$programa"; then' >> /tmp/comprobacion
echo '            echo -e "$programa\t${turquesa}(Servicio)${borra_colores}\t${verde}[OK]${borra_colores}"' >> /tmp/comprobacion
echo '        elif command -v "$programa" >/dev/null 2>&1; then' >> /tmp/comprobacion
echo '            echo -e "$programa\t${naranja}(Por repositorio añadido)${borra_colores}\t${verde}[OK]${borra_colores}"' >> /tmp/comprobacion
echo '        else' >> /tmp/comprobacion
echo '            echo -e "$programa\t${rojo}[No instalado]${borra_colores}\t${rojo}[FALLO]${borra_colores}"' >> /tmp/comprobacion
echo '        fi' >> /tmp/comprobacion
echo '    done' >> /tmp/comprobacion
echo '} | column -t -s $'\''\t'\''' >> /tmp/comprobacion
echo '' >> /tmp/comprobacion
echo 'echo ""' >> /tmp/comprobacion
echo 'read -p " Pulsa una tecla para continuar." pause' >> /tmp/comprobacion
}

