    add_repo "deb http://deb.debian.org/debian/ bookworm-updates main"
    add_repo "deb http://security.debian.org/debian-security bookworm-security main"
    sleep 3

    #actualiza el sistema
    sudo apt update
    sudo apt -y upgrade

    #instala extrepo
    sudo $instalar extrepo
    #configura el fichero de extrep para poder metes repositorios no oficales
    CONFIG_FILE="/etc/extrepo/config.yaml"

    #Verificar si el fichero existe
    if [[ -f "$CONFIG_FILE" ]]; then
        # Usar sed para asegurar que las líneas empiecen con "-"
        sudo sed -i -E \
        -e 's/^#?[[:space:]]*- main/- main/' \
        -e 's/^#?[[:space:]]*- contrib/- contrib/' \
        -e 's/^#?[[:space:]]*- non-free/- non-free/' \
        "$CONFIG_FILE"
    fi

else
    #añade los repositorios de debian
    FILE="/etc/apt/sources.list"

    add_repo () {
    LINE="$1"
    if ! grep -Fxq "$LINE" "$FILE"; then
        echo "$LINE" | sudo tee -a "$FILE" > /dev/null
        echo -e "${verde} Añadido:${borra_colores} $LINE${verde} OK"
    else
        echo -e "${amarillo} Ya existe:${borra_colores} $LINE"
    fi
    }
    add_repo "deb https://ftp.debian.org/debian/ trixie contrib main non-free non-free-firmware"
    add_repo "# deb-src https://ftp.debian.org/debian/ trixie contrib main non-free non-free-firmware"
    add_repo "deb https://ftp.debian.org/debian/ trixie-updates contrib main non-free non-free-firmware"
