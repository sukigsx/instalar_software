    add_repo "deb https://ftp.debian.org/debian/ trixie-proposed-updates contrib main non-free non-free-firmware"
    add_repo "# deb-src https://ftp.debian.org/debian/ trixie-proposed-updates contrib main non-free non-free-firmware"
    add_repo "deb https://security.debian.org/debian-security/ trixie-security contrib main non-free non-free-firmware"
    add_repo "# deb-src https://security.debian.org/debian-security/ trixie-security contrib main non-free non-free-firmware"
    add_repo "deb https://ftp.debian.org/debian/ trixie-backports contrib main non-free non-free-firmware"
    add_repo "# deb-src https://ftp.debian.org/debian/ trixie-backports contrib main non-free non-free-firmware"
    add_repo "deb http://deb.debian.org/debian/ bookworm main"
    add_repo "deb http://deb.debian.org/debian/ bookworm-updates main"
    add_repo "deb http://security.debian.org/debian-security bookworm-security main"
    sleep 3
    if ! command -v extrepo >/dev/null 2>&1; then
        echo ""
        echo -e "${rojo} No es posible continuar.${borra_colores}"
        echo -e "${amarillo} Puede ocasionar fallos en la instalacion de paquetes${borra_colores}"
        echo -e "${amarillo} sino esta instalado extrepo.${borra_colores}"
        echo ""
        echo -e "${azul} GRACIAS POR UTILIZAR MI SCRIPT${borra_colores}"
        echo ""
        exit
    fi
fi
}


